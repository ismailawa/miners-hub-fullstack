.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# IDE
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Environment files
.env
.env.local
.env.*.local
.env.test
.env.production

# Test artifacts
**/coverage/
**/.nyc_output/
**/test-results/
**/playwright-report/
**/playwright/.cache/
*.lcov

# Build outputs
**/dist/
**/build/
**/.next/
**/out/

# Temporary files
*.tmp
*.temp
.cache/

# Package manager
**/node_modules/
**/.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# TypeScript
*.tsbuildinfo

# Vercel
.vercel

# Railway
.railway

# AI files
bmad

